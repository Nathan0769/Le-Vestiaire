generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model User {
  id                          String                @id @default(cuid())
  name                        String
  email                       String                @unique
  emailVerified               Boolean               @default(false)
  image                       String?
  firstName                   String?
  lastName                    String?
  avatar                      String?
  bio                         String?
  favoriteClubId              String?
  createdAt                   DateTime              @default(now())
  updatedAt                   DateTime              @updatedAt
  username                    String                @unique
  usernameGenerated           Boolean               @default(false) @map("username_generated")
  leaderboardAnonymous        Boolean?              @default(true) @map("leaderboard_anonymous")
  role                        String                @default("user")
  banned                      Boolean               @default(false)
  banReason                   String?
  banExpiresIn                BigInt?
  contributionsCount          Int                   @default(0)
  approvedContributionsCount  Int                   @default(0)
  plan                        UserPlan              @default(FREE)
  stripeCustomerId            String?
  lastLoginMethod             String?
  emailMarketing              Boolean               @default(true) @map("email_marketing")
  reminderStep                Int                   @default(0) @map("reminder_step")
  notificationsEnabled        Boolean               @default(true) @map("notifications_enabled")
  isPrivate                   Boolean               @default(false) @map("is_private")
  lastAchievementsSeenAt      DateTime?             @map("last_achievements_seen_at") @db.Timestamp(6)
  lastAchievementsFullCheckAt DateTime?             @map("last_achievements_full_check_at") @db.Timestamp(6)
  instagramHandle             String?
  twitterHandle               String?
  tiktokHandle                String?
  youtubeHandle               String?
  twitchHandle                String?
  accounts                    Account[]
  achievements                Achievement[]
  contributionHistory         ContributionHistory[]
  reviewedDescriptions        DescriptionProposal[] @relation("ReviewedDescriptions")
  descriptionProposals        DescriptionProposal[]
  jerseyProposals             JerseyProposal[]
  pushTokens                  PushToken[]
  ratings                     Rating[]
  sessions                    Session[]
  favoriteClub                Club?                 @relation(fields: [favoriteClubId], references: [id])
  collection                  UserJersey[]
  wishlist                    Wishlist[]
  reportedJerseys             JerseyReport[]        @relation("ReportedBy")
  resolvedReports             JerseyReport[]        @relation("ReportResolver")
  followers                   Follow[]              @relation("Following")
  following                   Follow[]              @relation("Follower")
  followRequestsSent          FollowRequest[]       @relation("FollowRequestRequester")
  followRequestsReceived      FollowRequest[]       @relation("FollowRequestTarget")
  blocksSent                  Block[]               @relation("Blocker")
  blocksReceived              Block[]               @relation("Blocked")
  posts                       Post[]
  postLikes                   PostLike[]
  postComments                PostComment[]
  postReportsSent             PostReport[]          @relation("PostReportReporter")
  postReportsReviewed         PostReport[]          @relation("PostReportReviewer")
  notifications               Notification[]        @relation("NotificationRecipient")
  notificationsActedOn        Notification[]        @relation("NotificationActor")

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime
  token     String   @unique
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  scope                 String?
  providerId            String
  accessToken           String?
  accessTokenExpiresAt  DateTime?
  createdAt             DateTime  @default(now())
  idToken               String?
  password              String?
  refreshToken          String?
  refreshTokenExpiresAt DateTime?
  updatedAt             DateTime  @updatedAt
  accountId             String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@map("accounts")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@unique([identifier, value])
  @@map("verification")
}

model Jersey {
  id                      String                @id @default(cuid())
  name                    String
  clubId                  String
  season                  String
  type                    JerseyType
  brand                   String
  imageUrl                String
  retailPrice             Decimal?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  description             String?
  slug                    String?               @unique
  descriptionTranslations Json?
  variant                 Int                   @default(1)
  mainColor               String?
  descriptionProposals    DescriptionProposal[]
  club                    Club                  @relation(fields: [clubId], references: [id])
  ratings                 Rating[]
  collection              UserJersey[]
  wishlist                Wishlist[]
  reports                 JerseyReport[]
  cfsPromos               CfsPromo[]
  cfsAvailability         CfsAvailability?

  @@unique([clubId, season, type, variant])
  @@index([clubId], map: "idx_jerseys_club_id")
  @@index([createdAt(sort: Desc)], map: "idx_jerseys_createdat")
  @@map("jerseys")
}

model JerseyReport {
  id          String               @id @default(cuid())
  jerseyId    String
  userId      String
  category    JerseyReportCategory
  description String?
  status      JerseyReportStatus   @default(PENDING)
  createdAt   DateTime             @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?

  jersey   Jersey @relation(fields: [jerseyId], references: [id], onDelete: Cascade)
  user     User   @relation("ReportedBy", fields: [userId], references: [id], onDelete: Cascade)
  resolver User?  @relation("ReportResolver", fields: [resolvedBy], references: [id], onDelete: SetNull)

  @@index([jerseyId])
  @@index([userId])
  @@index([status])
  @@map("jersey_reports")
}

enum JerseyReportCategory {
  LETTERING
  SEASON
  BRAND
  IMAGE
  OTHER
}

enum JerseyReportStatus {
  PENDING
  RESOLVED
  REJECTED
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  jerseyId  String
  rating    Decimal
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  jersey    Jersey   @relation(fields: [jerseyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jerseyId])
  @@index([jerseyId, rating, id], map: "idx_ratings_jersey_agg")
  @@index([jerseyId], map: "idx_ratings_jersey_id")
  @@map("ratings")
}

model UserJersey {
  id                 String            @id @default(cuid())
  userId             String
  jerseyId           String
  size               Size?
  condition          Condition
  hasTags            Boolean           @default(false)
  purchasePrice      Decimal?
  purchaseDate       DateTime?
  notes              String?
  userPhotoUrl       String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  isFromMysteryBox   Boolean           @default(false)
  isGift             Boolean           @default(false)
  playerName         String?
  playerNumber       Int?
  version            JerseyVersion     @default(REPLICA)
  isSigned           Boolean           @default(false)
  signedBy           String?
  hasAuthCertificate Boolean           @default(false)
  matchDescription   String?
  matchDate          DateTime?
  certificateUrl     String?
  hasLongSleeves     Boolean           @default(false)
  pinnedAt           DateTime?
  jersey             Jersey            @relation(fields: [jerseyId], references: [id], onDelete: Cascade)
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  patches            UserJerseyPatch[]

  @@index([userId])
  @@index([jerseyId])
  @@index([userId, pinnedAt])
  @@map("user_jerseys")
}

model Patch {
  id              String            @id @default(cuid())
  name            String
  family          PatchFamily
  leagueId        String?
  isActive        Boolean           @default(true)
  notes           String?
  eligibleClubIds String[]          @default([])
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  league          League?           @relation(fields: [leagueId], references: [id], onDelete: SetNull)
  versions        PatchVersion[]
  userPatches     UserJerseyPatch[]

  @@index([family])
  @@index([leagueId])
  @@index([isActive])
  @@map("patches")
}

model PatchVersion {
  id          String   @id @default(cuid())
  patchId     String
  seasonStart String
  seasonEnd   String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  patch       Patch    @relation(fields: [patchId], references: [id], onDelete: Cascade)

  @@index([patchId])
  @@map("patch_versions")
}

model UserJerseyPatch {
  id           String     @id @default(cuid())
  userJerseyId String
  patchId      String?
  customLabel  String?
  createdAt    DateTime   @default(now())
  userJersey   UserJersey @relation(fields: [userJerseyId], references: [id], onDelete: Cascade)
  patch        Patch?     @relation(fields: [patchId], references: [id], onDelete: SetNull)

  @@unique([userJerseyId, patchId])
  @@index([userJerseyId])
  @@index([patchId])
  @@map("user_jersey_patches")
}

model Club {
  id                String             @id @default(cuid())
  name              String
  shortName         String
  leagueId          String
  logoUrl           String
  primaryColor      String
  apiFootballTeamId Int?
  trophies          ClubTrophy[]
  league            League             @relation(fields: [leagueId], references: [id])
  jerseyProposals   JerseyProposal[]
  jerseys           Jersey[]
  seasonPlayers     SeasonPlayer[]
  seasonLeagues     ClubSeasonLeague[]
  favoriteBy        User[]
  cfsAliases        CfsClubAlias[]

  @@index([leagueId], map: "idx_clubs_league_id")
  @@map("clubs")
}

model ClubSeasonLeague {
  id        String   @id @default(cuid())
  clubId    String
  season    String
  leagueId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  league    League   @relation(fields: [leagueId], references: [id])

  @@unique([clubId, season])
  @@index([clubId])
  @@index([leagueId])
  @@map("club_season_leagues")
}

model ClubTrophy {
  id          String   @id @default(cuid())
  clubId      String
  competition String
  country     String
  season      String
  place       String
  fetchedAt   DateTime @default(now())
  club        Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, competition, season, place])
  @@index([clubId, season])
  @@map("club_trophies")
}

model League {
  id          String             @id @default(cuid())
  name        String
  country     String
  logoUrl     String
  tier        Int                @default(1)
  logoDarkUrl String?
  clubs       Club[]
  clubSeasons ClubSeasonLeague[]
  patches     Patch[]

  @@map("leagues")
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  jerseyId  String
  priority  Int      @default(1)
  createdAt DateTime @default(now())
  jersey    Jersey   @relation(fields: [jerseyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jerseyId])
  @@map("wishlist")
}

enum AchievementCategory {
  COLLECTION
  DIVERSITY
  SOCIAL
  LEADERBOARD
  LOYALTY
  RARITY
  CONTRIBUTION
}

model Achievement {
  id         String              @id @default(cuid())
  userId     String              @map("user_id")
  key        String
  category   AchievementCategory
  tier       String?
  unlockedAt DateTime            @default(now()) @map("unlocked_at") @db.Timestamp(6)
  metadata   Json?
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId, unlockedAt])
  @@map("achievements")
}

model JerseyProposal {
  id          String     @id @default(cuid())
  userId      String
  name        String
  clubId      String
  season      String
  type        JerseyType
  brand       String
  imageUrl    String
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  club        Club       @relation(fields: [clubId], references: [id])
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clubId])
  @@map("jersey_proposals")
}

model ContributionHistory {
  id        String   @id @default(cuid())
  userId    String
  jerseyId  String?
  action    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("contribution_history")
}

model SeasonPlayer {
  id            String          @id @default(cuid())
  clubId        String
  season        String
  name          String
  number        Int?
  position      PlayerPosition?
  photoUrl      String?
  goals         Int?
  assists       Int?
  matches       Int?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  cleanSheets   Int?
  goalsConceded Int?
  club          Club            @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId, season])
  @@map("season_players")
}

model DescriptionProposal {
  id              String         @id @default(cuid())
  userId          String
  jerseyId        String
  description     String
  status          ProposalStatus @default(PENDING)
  rejectionReason String?
  reviewedBy      String?
  reviewedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  jersey          Jersey         @relation(fields: [jerseyId], references: [id], onDelete: Cascade)
  reviewer        User?          @relation("ReviewedDescriptions", fields: [reviewedBy], references: [id])
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([jerseyId])
  @@index([status])
  @@map("description_proposals")
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_tokens")
}

model CfsPromo {
  id           String         @id @default(cuid())
  name         String
  imageUrl     String
  price        Decimal
  promoPrice   Decimal
  affiliateUrl String
  club         String?
  brand        String?
  isActive     Boolean        @default(true)
  position     Int            @default(0)
  source       String         @default("clearance")
  sizes        String[]       @default([])
  season       String?
  type         JerseyType?
  jerseyId     String?
  jersey       Jersey?        @relation(fields: [jerseyId], references: [id], onDelete: SetNull)
  matchStatus  CfsMatchStatus @default(PENDING)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @default(now()) @updatedAt

  @@index([jerseyId])
  @@index([matchStatus])
  @@map("cfs_promos")
}

model CfsClubAlias {
  id        String   @id @default(cuid())
  cfsName   String   @unique
  clubId    String
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId])
  @@map("cfs_club_aliases")
}

model CfsAvailability {
  id           String   @id @default(cuid())
  jerseyId     String   @unique
  jersey       Jersey   @relation(fields: [jerseyId], references: [id], onDelete: Cascade)
  price        Decimal
  promoPrice   Decimal?
  productUrl   String
  affiliateUrl String
  imageUrl     String
  lastSeenAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([lastSeenAt])
  @@map("cfs_availability")
}

model stripe_events {
  id        String   @id
  type      String
  processed Boolean  @default(true)
  createdAt DateTime @default(now())
}

enum UserPlan {
  FREE
  PRO
}

enum CfsMatchStatus {
  PENDING
  MATCHED
  NEEDS_ALIAS
  NO_JERSEY
  PARSE_FAILED
}

enum JerseyVersion {
  REPLICA
  AUTHENTIC
  STOCK_PRO
  PLAYER_ISSUE
  MATCH_WORN
}

enum JerseyType {
  HOME
  AWAY
  THIRD
  GOALKEEPER
  SPECIAL
  FOURTH
  HALLOWEEN
  ANNIVERSARY
  CENTENAIRE
  OKTOBERFEST
  HUMANRACE
  ONE_PLANET
  OCTOBRE_ROSE
  ANTI_RACISME
  HOMMAGE
  RETRO
  NOUVEL_AN_CHINOIS
  OFF_WHITE
  KOCHE
  CHAMPION
}

enum Size {
  XS
  S
  M
  L
  XL
  XXL
}

enum Condition {
  MINT
  EXCELLENT
  GOOD
  FAIR
  POOR
}

enum ProposalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PlayerPosition {
  GOALKEEPER
  DEFENDER
  MIDFIELDER
  FORWARD
}

enum PatchFamily {
  UEFA_COMPETITION
  CONFED_CLUB_COMPETITION
  FIFA_CLUB_COMPETITION
  DOMESTIC_LEAGUE_BADGE
  DOMESTIC_CHAMPION
  DOMESTIC_CUP
  DOMESTIC_SUPERCUP
  NATIONAL_TEAM_COMPETITION
  CUSTOM
}

// ============================================================================
// Feed communautaire (Follow, Block, Post, Interactions, Reports, Notifications)
// ============================================================================

model Follow {
  id          String   @id @default(cuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId, createdAt])
  @@index([followerId, createdAt])
  @@map("follows")
}

model FollowRequest {
  id          String   @id @default(cuid())
  requesterId String   @map("requester_id")
  targetId    String   @map("target_id")
  createdAt   DateTime @default(now()) @map("created_at")
  requester   User     @relation("FollowRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  target      User     @relation("FollowRequestTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([requesterId, targetId])
  @@index([targetId, createdAt])
  @@map("follow_requests")
}

model Block {
  id        String   @id @default(cuid())
  blockerId String   @map("blocker_id")
  blockedId String   @map("blocked_id")
  createdAt DateTime @default(now()) @map("created_at")
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
  @@map("blocks")
}

enum PostType {
  JERSEY_ADD
  ACHIEVEMENT_UNLOCK
  CAP_REACHED
}

enum CapKind {
  COLLECTION_50
  COLLECTION_100
  COLLECTION_500
  COLLECTION_1000
  VALUE_1K
  VALUE_5K
  VALUE_25K
}

model Post {
  id           String    @id @default(cuid())
  authorId     String    @map("author_id")
  type         PostType
  referenceId  String?   @map("reference_id")
  capKind      CapKind?  @map("cap_kind")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  boost        Int       @default(0)
  likeCount    Int       @default(0) @map("like_count")
  commentCount Int       @default(0) @map("comment_count")

  author   User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes    PostLike[]
  comments PostComment[]
  reports  PostReport[]

  @@unique([authorId, type, referenceId, capKind])
  @@index([authorId, createdAt])
  @@index([createdAt, boost])
  @@index([type, createdAt])
  @@map("posts")
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
  @@map("post_likes")
}

model PostComment {
  id        String    @id @default(cuid())
  postId    String    @map("post_id")
  authorId  String    @map("author_id")
  content   String    @db.VarChar(500)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  post    Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reports PostReport[]

  @@index([postId, createdAt])
  @@index([authorId])
  @@map("post_comments")
}

enum PostReportTargetType {
  POST
  COMMENT
}

enum PostReportStatus {
  PENDING
  REVIEWED_KEPT
  REVIEWED_REMOVED
}

enum PostReportReason {
  SPAM
  HARASSMENT
  HATE_SPEECH
  INAPPROPRIATE
  OTHER
}

model PostReport {
  id           String               @id @default(cuid())
  reporterId   String               @map("reporter_id")
  targetType   PostReportTargetType @map("target_type")
  postId       String?              @map("post_id")
  commentId    String?              @map("comment_id")
  reason       PostReportReason
  details      String?              @db.VarChar(500)
  status       PostReportStatus     @default(PENDING)
  reviewedById String?              @map("reviewed_by_id")
  reviewedAt   DateTime?            @map("reviewed_at")
  createdAt    DateTime             @default(now()) @map("created_at")

  reporter   User         @relation("PostReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewedBy User?        @relation("PostReportReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  // SetNull volontaire : préserve l'audit trail du signalement même si le post/comment
  // est supprimé (par l'auteur ou la modération). reason/details/reporter restent traçables.
  post       Post?        @relation(fields: [postId], references: [id], onDelete: SetNull)
  comment    PostComment? @relation(fields: [commentId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([reporterId])
  @@map("post_reports")
}

enum NotificationType {
  NEW_FOLLOWER
  POST_LIKED
  POST_COMMENTED
  FOLLOW_REQUEST_APPROVED
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  actorId   String?          @map("actor_id")
  postId    String?          @map("post_id")
  commentId String?          @map("comment_id")
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user  User  @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, readAt, createdAt])
  @@map("notifications")
}
