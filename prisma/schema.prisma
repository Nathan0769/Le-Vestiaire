generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model User {
  id                         String                @id @default(cuid())
  name                       String
  email                      String                @unique
  emailVerified              Boolean               @default(false)
  image                      String?
  firstName                  String?
  lastName                   String?
  avatar                     String?
  bio                        String?
  favoriteClubId             String?
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt
  username                   String?
  leaderboardAnonymous       Boolean?              @default(true) @map("leaderboard_anonymous")
  role                       String                @default("user")
  banned                     Boolean               @default(false)
  banReason                  String?
  banExpiresIn               BigInt?
  contributionsCount         Int                   @default(0)
  approvedContributionsCount Int                   @default(0)
  plan                       UserPlan              @default(FREE)
  stripeCustomerId           String?
  lastLoginMethod            String?
  emailMarketing             Boolean               @default(true) @map("email_marketing")
  reminderStep               Int                   @default(0) @map("reminder_step")
  notificationsEnabled       Boolean               @default(true) @map("notifications_enabled")
  accounts                   Account[]
  achievements               Achievement[]
  contributionHistory        ContributionHistory[]
  reviewedDescriptions       DescriptionProposal[] @relation("ReviewedDescriptions")
  descriptionProposals       DescriptionProposal[]
  receivedFriendships        Friendship[]          @relation("ReceivedFriendships")
  sentFriendships            Friendship[]          @relation("SentFriendships")
  jerseyProposals            JerseyProposal[]
  pushTokens                 PushToken[]
  ratings                    Rating[]
  sessions                   Session[]
  favoriteClub               Club?                 @relation(fields: [favoriteClubId], references: [id])
  collection                 UserJersey[]
  wishlist                   Wishlist[]
  reportedJerseys            JerseyReport[]        @relation("ReportedBy")
  resolvedReports            JerseyReport[]        @relation("ReportResolver")

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime
  token     String   @unique
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  scope                 String?
  providerId            String
  accessToken           String?
  accessTokenExpiresAt  DateTime?
  createdAt             DateTime  @default(now())
  idToken               String?
  password              String?
  refreshToken          String?
  refreshTokenExpiresAt DateTime?
  updatedAt             DateTime  @updatedAt
  accountId             String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@map("accounts")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@unique([identifier, value])
  @@map("verification")
}

model Jersey {
  id                      String                @id @default(cuid())
  name                    String
  clubId                  String
  season                  String
  type                    JerseyType
  brand                   String
  imageUrl                String
  retailPrice             Decimal?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  description             String?
  slug                    String?               @unique
  descriptionTranslations Json?
  variant                 Int                   @default(1)
  mainColor               String?
  descriptionProposals    DescriptionProposal[]
  club                    Club                  @relation(fields: [clubId], references: [id])
  ratings                 Rating[]
  collection              UserJersey[]
  wishlist                Wishlist[]
  reports                 JerseyReport[]

  @@unique([clubId, season, type, variant])
  @@index([clubId], map: "idx_jerseys_club_id")
  @@index([createdAt(sort: Desc)], map: "idx_jerseys_createdat")
  @@map("jerseys")
}

model JerseyReport {
  id          String               @id @default(cuid())
  jerseyId    String
  userId      String
  category    JerseyReportCategory
  description String?
  status      JerseyReportStatus   @default(PENDING)
  createdAt   DateTime             @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?

  jersey   Jersey @relation(fields: [jerseyId], references: [id], onDelete: Cascade)
  user     User   @relation("ReportedBy", fields: [userId], references: [id], onDelete: Cascade)
  resolver User?  @relation("ReportResolver", fields: [resolvedBy], references: [id], onDelete: SetNull)

  @@index([jerseyId])
  @@index([userId])
  @@index([status])
  @@map("jersey_reports")
}

enum JerseyReportCategory {
  LETTERING
  SEASON
  BRAND
  IMAGE
  OTHER
}

enum JerseyReportStatus {
  PENDING
  RESOLVED
  REJECTED
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  jerseyId  String
  rating    Decimal
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  jersey    Jersey   @relation(fields: [jerseyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jerseyId])
  @@index([jerseyId, rating, id], map: "idx_ratings_jersey_agg")
  @@index([jerseyId], map: "idx_ratings_jersey_id")
  @@map("ratings")
}

model UserJersey {
  id                 String            @id @default(cuid())
  userId             String
  jerseyId           String
  size               Size?
  condition          Condition
  hasTags            Boolean           @default(false)
  purchasePrice      Decimal?
  purchaseDate       DateTime?
  notes              String?
  userPhotoUrl       String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  isFromMysteryBox   Boolean           @default(false)
  isGift             Boolean           @default(false)
  playerName         String?
  playerNumber       Int?
  version            JerseyVersion     @default(REPLICA)
  isSigned           Boolean           @default(false)
  signedBy           String?
  hasAuthCertificate Boolean           @default(false)
  matchDescription   String?
  matchDate          DateTime?
  certificateUrl     String?
  hasLongSleeves     Boolean           @default(false)
  jersey             Jersey            @relation(fields: [jerseyId], references: [id], onDelete: Cascade)
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  patches            UserJerseyPatch[]

  @@index([userId])
  @@index([jerseyId])
  @@map("user_jerseys")
}

model Patch {
  id          String            @id @default(cuid())
  name        String
  family      PatchFamily
  leagueId    String?
  isActive    Boolean           @default(true)
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  league      League?           @relation(fields: [leagueId], references: [id], onDelete: SetNull)
  versions    PatchVersion[]
  userPatches UserJerseyPatch[]

  @@index([family])
  @@index([leagueId])
  @@index([isActive])
  @@map("patches")
}

model PatchVersion {
  id          String   @id @default(cuid())
  patchId     String
  seasonStart String
  seasonEnd   String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  patch       Patch    @relation(fields: [patchId], references: [id], onDelete: Cascade)

  @@index([patchId])
  @@map("patch_versions")
}

model UserJerseyPatch {
  id           String     @id @default(cuid())
  userJerseyId String
  patchId      String?
  customLabel  String?
  createdAt    DateTime   @default(now())
  userJersey   UserJersey @relation(fields: [userJerseyId], references: [id], onDelete: Cascade)
  patch        Patch?     @relation(fields: [patchId], references: [id], onDelete: SetNull)

  @@unique([userJerseyId, patchId])
  @@index([userJerseyId])
  @@index([patchId])
  @@map("user_jersey_patches")
}

model Club {
  id                String           @id @default(cuid())
  name              String
  shortName         String
  leagueId          String
  logoUrl           String
  primaryColor      String
  apiFootballTeamId Int?
  trophies          ClubTrophy[]
  league            League           @relation(fields: [leagueId], references: [id])
  jerseyProposals   JerseyProposal[]
  jerseys           Jersey[]
  seasonPlayers     SeasonPlayer[]
  favoriteBy        User[]

  @@index([leagueId], map: "idx_clubs_league_id")
  @@map("clubs")
}

model ClubTrophy {
  id          String   @id @default(cuid())
  clubId      String
  competition String
  country     String
  season      String
  place       String
  fetchedAt   DateTime @default(now())
  club        Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, competition, season, place])
  @@index([clubId, season])
  @@map("club_trophies")
}

model League {
  id          String  @id @default(cuid())
  name        String
  country     String
  logoUrl     String
  tier        Int     @default(1)
  logoDarkUrl String?
  clubs       Club[]
  patches     Patch[]

  @@map("leagues")
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  jerseyId  String
  priority  Int      @default(1)
  createdAt DateTime @default(now())
  jersey    Jersey   @relation(fields: [jerseyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jerseyId])
  @@map("wishlist")
}

model Friendship {
  id         String           @id @default(cuid())
  senderId   String
  receiverId String
  status     FriendshipStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  receiver   User             @relation("ReceivedFriendships", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User             @relation("SentFriendships", fields: [senderId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@map("friendships")
}

model Achievement {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  badgeType  String   @map("badge_type")
  badgeMonth String?  @map("badge_month")
  rank       Int
  category   String
  metadata   Json?
  earnedAt   DateTime @default(now()) @map("earned_at") @db.Timestamp(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user")

  @@unique([userId, badgeType, badgeMonth, category], name: "unique_monthly_badge", map: "unique_monthly_badge")
  @@map("achievements")
}

model JerseyProposal {
  id          String     @id @default(cuid())
  userId      String
  name        String
  clubId      String
  season      String
  type        JerseyType
  brand       String
  imageUrl    String
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  club        Club       @relation(fields: [clubId], references: [id])
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clubId])
  @@map("jersey_proposals")
}

model ContributionHistory {
  id        String   @id @default(cuid())
  userId    String
  jerseyId  String?
  action    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("contribution_history")
}

model SeasonPlayer {
  id            String          @id @default(cuid())
  clubId        String
  season        String
  name          String
  number        Int?
  position      PlayerPosition?
  photoUrl      String?
  goals         Int?
  assists       Int?
  matches       Int?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  cleanSheets   Int?
  goalsConceded Int?
  club          Club            @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId, season])
  @@map("season_players")
}

model DescriptionProposal {
  id              String         @id @default(cuid())
  userId          String
  jerseyId        String
  description     String
  status          ProposalStatus @default(PENDING)
  rejectionReason String?
  reviewedBy      String?
  reviewedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  jersey          Jersey         @relation(fields: [jerseyId], references: [id], onDelete: Cascade)
  reviewer        User?          @relation("ReviewedDescriptions", fields: [reviewedBy], references: [id])
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([jerseyId])
  @@index([status])
  @@map("description_proposals")
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_tokens")
}

model CfsPromo {
  id           String   @id @default(cuid())
  name         String
  imageUrl     String
  price        Decimal
  promoPrice   Decimal
  affiliateUrl String
  club         String?
  brand        String?
  isActive     Boolean  @default(true)
  position     Int      @default(0)
  source       String   @default("clearance")
  sizes        String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  @@map("cfs_promos")
}

model stripe_events {
  id        String   @id
  type      String
  processed Boolean  @default(true)
  createdAt DateTime @default(now())
}

enum UserPlan {
  FREE
  PRO
}

enum JerseyVersion {
  REPLICA
  AUTHENTIC
  STOCK_PRO
  PLAYER_ISSUE
  MATCH_WORN
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

enum JerseyType {
  HOME
  AWAY
  THIRD
  GOALKEEPER
  SPECIAL
  FOURTH
  HALLOWEEN
  ANNIVERSARY
  CENTENAIRE
  OKTOBERFEST
  HUMANRACE
  ONE_PLANET
  OCTOBRE_ROSE
  ANTI_RACISME
  HOMMAGE
  RETRO
  NOUVEL_AN_CHINOIS
  OFF_WHITE
  KOCHE
  CHAMPION
}

enum Size {
  XS
  S
  M
  L
  XL
  XXL
}

enum Condition {
  MINT
  EXCELLENT
  GOOD
  FAIR
  POOR
}

enum ProposalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PlayerPosition {
  GOALKEEPER
  DEFENDER
  MIDFIELDER
  FORWARD
}

enum PatchFamily {
  UEFA_COMPETITION
  CONFED_CLUB_COMPETITION
  FIFA_CLUB_COMPETITION
  DOMESTIC_LEAGUE_BADGE
  DOMESTIC_CHAMPION
  DOMESTIC_CUP
  DOMESTIC_SUPERCUP
  NATIONAL_TEAM_COMPETITION
  CUSTOM
}
